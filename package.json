  "main": "src/server.js",
  "scripts": {
    "preinstall": "mkdir -p frontend && git clone https://github.com/GimaCapital/thespark-frontend.git temp-frontend && cp -r temp-frontend/src frontend/ && rm -rf temp-frontend",
